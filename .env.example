# AgileOS BPM Platform - Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control!

# ============================================
# DATABASE (SurrealDB)
# ============================================
SURREAL_USER=root
SURREAL_PASS=your_secure_password_here
SURREAL_URL=ws://agileos-db:8000/rpc
SURREAL_EXTERNAL_PORT=8002  # External port to avoid conflicts

# ============================================
# MESSAGE BROKER (NATS)
# ============================================
NATS_URL=nats://agileos-nats:4222
NATS_EXTERNAL_PORT=4223      # External port to avoid conflicts
NATS_MONITOR_PORT=8223       # External monitor port

# ============================================
# BACKEND (Go API)
# ============================================
PORT=8080
BACKEND_EXTERNAL_PORT=8081   # External port to avoid conflicts
GIN_MODE=release

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRY_HOURS=24
REFRESH_TOKEN_EXPIRY_DAYS=7

# ============================================
# FRONTEND (Next.js)
# ============================================
NODE_ENV=production
NEXT_PUBLIC_API_URL=http://localhost:8081  # Updated to new backend port
PORT=3000
FRONTEND_EXTERNAL_PORT=3001  # External port to avoid conflicts

# ============================================
# NGINX (Reverse Proxy)
# ============================================
NGINX_HTTP_PORT=8090         # Changed from 80 to avoid conflicts
NGINX_HTTPS_PORT=8443        # Changed from 443 to avoid conflicts

# ============================================
# AZURE DEPLOYMENT (Optional)
# ============================================
# Azure Container Registry
ACR_NAME=your_acr_name
ACR_LOGIN_SERVER=your_acr_name.azurecr.io
AZURE_SUBSCRIPTION_ID=your_subscription_id
AZURE_RESOURCE_GROUP=agileos-rg
AZURE_LOCATION=southeastasia

# Azure VM (if using VM deployment)
AZURE_VM_NAME=agileos-vm
AZURE_VM_ADMIN=azureuser
AZURE_VM_IP=your_vm_public_ip

# ============================================
# DOCKER REGISTRY (Docker Hub or ACR)
# ============================================
DOCKER_REGISTRY=docker.io
DOCKER_USERNAME=your_dockerhub_username
DOCKER_PASSWORD=your_dockerhub_password

# Image tags
IMAGE_TAG=latest
BACKEND_IMAGE=${DOCKER_REGISTRY}/${DOCKER_USERNAME}/agileos-backend:${IMAGE_TAG}
FRONTEND_IMAGE=${DOCKER_REGISTRY}/${DOCKER_USERNAME}/agileos-frontend:${IMAGE_TAG}

# ============================================
# SSL/TLS (for HTTPS)
# ============================================
SSL_CERT_PATH=./deploy/nginx/ssl/cert.pem
SSL_KEY_PATH=./deploy/nginx/ssl/key.pem

# ============================================
# MONITORING & LOGGING (Optional)
# ============================================
LOG_LEVEL=info
ENABLE_METRICS=true
